---
import MotionVenueVisual from './MotionVenueVisual';
---

<section class="section section--venue" id="location">
	<div class="container venue venue--motion">
		<div class="venue__copy" data-reveal>
			<span class="eyebrow">La location</span>
			<h2 class="section-title">Agueta du Sciria, tra ulivi, quiete e luce ligure.</h2>
			<p class="body-lg">
				Abbiamo scelto un ristorante immerso nel verde di Arenzano, raccolto tra cielo e mare,
				con un'atmosfera accogliente e il ritmo rilassato della Riviera ligure.
			</p>

			<div class="venue__chips">
				<span class="detail-chip">Cerimonia ore 16:30</span>
				<span class="detail-chip">Arenzano, Genova</span>
				<span class="detail-chip">Immerso nel verde</span>
			</div>

			<div class="bezel venue-details">
				<div class="bezel__inner venue-details__inner">
					<div class="detail-row">
						<span class="detail-row__label">Indirizzo</span>
						<span class="detail-row__value">Via Pecorara 18/a, 16011 Arenzano (GE)</span>
					</div>
					<div class="detail-row">
						<span class="detail-row__label">Accoglienza</span>
						<span class="detail-row__value">Dalle 15:45 con welcome drink</span>
					</div>
					<div class="venue-details__action">
						<a
							class="button button--secondary venue-details__map-link"
							href="https://www.google.com/maps/search/?api=1&query=Agueta%20du%20Sciria%20Via%20Pecorara%2018%2Fa%2016011%20Arenzano%20GE"
							target="_blank"
							rel="noreferrer"
							aria-label="Apri la posizione del ristorante su Google Maps"
						>
							<span>Apri la mappa</span>
							<span class="button__icon" aria-hidden="true">↗</span>
						</a>
					</div>
				</div>
			</div>
		</div>

		<MotionVenueVisual client:visible={{ rootMargin: '96px' }} />
	</div>
</section>
