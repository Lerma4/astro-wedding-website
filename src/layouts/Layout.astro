---
import logoImg from '../assets/logo.webp';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Igor e Eleonora | Matrimonio',
	description = 'Una landing page matrimonio elegante con dettagli della giornata, location e lista nozze.',
} = Astro.props;
---

<!doctype html>
<html lang="it" class="is-loading">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#faf7f2" />
		<style is:inline>
			html.is-loading,
			html.is-loading body {
				overflow: hidden;
				background: #faf7f2;
			}

			.site-preloader {
				display: none;
			}

			html.is-loading .site-preloader {
				position: fixed;
				inset: 0;
				z-index: 40;
				display: grid;
				place-items: center;
				padding: 1.5rem;
				color: #2f2a28;
				background:
					radial-gradient(circle at 28% 20%, rgba(183, 110, 121, 0.18), transparent 28%),
					radial-gradient(circle at 72% 80%, rgba(216, 185, 138, 0.22), transparent 30%),
					#faf7f2;
				opacity: 1;
				transition:
					opacity 620ms cubic-bezier(0.32, 0.72, 0, 1),
					visibility 0ms linear 620ms;
			}

			html.is-ready .site-preloader {
				visibility: hidden;
				opacity: 0;
				pointer-events: none;
			}

			.preloader-card {
				width: min(21rem, 100%);
				padding: 0.45rem;
				border: 1px solid rgba(191, 165, 144, 0.24);
				border-radius: 2rem;
				background: rgba(255, 253, 252, 0.54);
				box-shadow: 0 24px 70px rgba(120, 97, 78, 0.1);
			}

			.preloader-card__inner {
				display: grid;
				gap: 1rem;
				justify-items: center;
				padding: 2.2rem 1.6rem;
				border-radius: calc(2rem - 0.45rem);
				background: rgba(255, 253, 252, 0.82);
				box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.7);
				text-align: center;
			}

			.preloader-mark {
				display: grid;
				place-items: center;
				width: 4.6rem;
				height: 4.6rem;
				border-radius: 999px;
				border: 1px solid rgba(183, 110, 121, 0.22);
				background: linear-gradient(135deg, rgba(183, 110, 121, 0.14), rgba(216, 185, 138, 0.2));
			}

			.preloader-logo {
				display: block;
				width: auto;
				height: 3.25rem;
			}

			.preloader-title {
				margin: 0;
				font-family: 'Cormorant Garamond', 'Times New Roman', serif;
				font-size: clamp(2rem, 9vw, 2.8rem);
				font-weight: 600;
				line-height: 0.95;
				letter-spacing: -0.04em;
			}

			.preloader-copy {
				margin: 0;
				font-family: 'Plus Jakarta Sans', 'Segoe UI', sans-serif;
				font-size: 0.72rem;
				font-weight: 600;
				letter-spacing: 0.2em;
				color: #7c8c7a;
				text-transform: uppercase;
			}

			.preloader-line {
				position: relative;
				overflow: hidden;
				width: min(10rem, 70%);
				height: 1px;
				background: rgba(221, 210, 198, 0.8);
			}

			.preloader-line::after {
				position: absolute;
				inset: 0;
				width: 42%;
				background: linear-gradient(90deg, transparent, #b76e79, transparent);
				content: '';
				transform: translateX(-100%);
				animation: preloader-line 1300ms cubic-bezier(0.32, 0.72, 0, 1) infinite;
			}

			@keyframes preloader-line {
				to {
					transform: translateX(240%);
				}
			}

			@media (prefers-reduced-motion: reduce) {
				.site-preloader,
				.preloader-line::after {
					animation: none;
					transition: none;
				}
			}
		</style>
		<noscript><style>.site-preloader { display: none !important; }</style></noscript>
		<script is:inline>
			(() => {
				const root = document.documentElement;
				let released = false;

				const release = () => {
					if (released) return;
					released = true;
					root.classList.add('is-ready');
					window.setTimeout(() => {
						root.classList.remove('is-loading');
					}, 660);
				};

				const pageLoaded = new Promise((resolve) => {
					if (document.readyState === 'complete') {
						resolve();
						return;
					}

					window.addEventListener('load', resolve, { once: true });
				});

				const fontsReady = 'fonts' in document
					? Promise.allSettled([
							document.fonts.load('1em "Plus Jakarta Sans"'),
							document.fonts.load('1em "Cormorant Garamond"'),
							document.fonts.ready,
						])
					: Promise.resolve();

				const safetyTimeout = new Promise((resolve) => window.setTimeout(resolve, 2800));

				Promise.race([Promise.all([pageLoaded, fontsReady]), safetyTimeout]).then(release, release);
			})();
		</script>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
		<title>{title}</title>
	</head>
	<body>
		<div class="site-preloader" role="status" aria-live="polite" aria-label="Caricamento sito">
			<div class="preloader-card">
				<div class="preloader-card__inner">
					<span class="preloader-mark" aria-hidden="true">
						<img class="preloader-logo" src={logoImg.src} alt="" loading="eager" decoding="sync" />
					</span>
					<p class="preloader-title">Igor e Eleonora</p>
					<p class="preloader-copy">Prepariamo l'invito</p>
					<span class="preloader-line" aria-hidden="true"></span>
				</div>
			</div>
		</div>
		<a class="skip-link" href="#contenuto">Vai al contenuto</a>
		<slot />

		<script is:inline>
			const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			if (!prefersReducedMotion) {
				const observer = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting) {
								entry.target.classList.add('is-visible');
								observer.unobserve(entry.target);
							}
						});
					},
					{ threshold: 0.18, rootMargin: '0px 0px -8% 0px' },
				);

				document.querySelectorAll('[data-reveal]').forEach((element) => observer.observe(element));
			} else {
				document.querySelectorAll('[data-reveal]').forEach((element) => element.classList.add('is-visible'));
			}
		</script>
	</body>
</html>

<style is:global>
	:root {
		--color-bg: #faf7f2;
		--color-surface: #fffdfc;
		--color-surface-muted: #f3eee7;
		--color-text: #2f2a28;
		--color-text-soft: #6f6660;
		--color-line: #ddd2c6;
		--color-primary: #b76e79;
		--color-primary-strong: #9e5965;
		--color-secondary: #7c8c7a;
		--color-highlight: #d8b98a;
		--shadow-soft: 0 24px 60px rgba(120, 97, 78, 0.08);
		--shadow-card: 0 16px 38px rgba(120, 97, 78, 0.05);
		--radius-xl: 2rem;
		--radius-lg: 1.5rem;
		--radius-pill: 999px;
		--container: 1120px;
		--narrow: 760px;
		--gutter: clamp(1.25rem, 3vw, 3rem);
		--ease-fluid: cubic-bezier(0.32, 0.72, 0, 1);
		--ease-soft: cubic-bezier(0.22, 1, 0.36, 1);
		--font-serif: 'Cormorant Garamond', 'Times New Roman', serif;
		--font-sans: 'Plus Jakarta Sans', 'Segoe UI', sans-serif;
	}

	* {
		box-sizing: border-box;
	}

	html {
		margin: 0;
		min-height: 100%;
		scroll-behavior: smooth;
		background: var(--color-bg);
	}

	body {
		margin: 0;
		min-height: 100%;
		font-family: var(--font-sans);
		color: var(--color-text);
		background:
			radial-gradient(circle at top right, rgba(183, 110, 121, 0.14), transparent 30%),
			radial-gradient(circle at bottom left, rgba(216, 185, 138, 0.18), transparent 24%),
			var(--color-bg);
		line-height: 1.65;
		text-rendering: optimizeLegibility;
		position: relative;
	}

	body[data-menu-open='true'] {
		overflow: hidden;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	img {
		display: block;
		max-width: 100%;
	}

	button,
	input,
	textarea,
	select {
		font: inherit;
	}

	button {
		background: none;
		border: 0;
		padding: 0;
		color: inherit;
		cursor: pointer;
	}

	:focus-visible {
		outline: 2px solid rgba(183, 110, 121, 0.55);
		outline-offset: 4px;
	}

	.skip-link {
		position: absolute;
		left: 1rem;
		top: -3rem;
		padding: 0.75rem 1rem;
		background: var(--color-surface);
		border-radius: 1rem;
		box-shadow: var(--shadow-card);
		transition: transform 420ms var(--ease-fluid);
		z-index: 5;
	}

	.skip-link:focus-visible {
		transform: translateY(4.5rem);
	}

	.page-shell {
		position: relative;
		overflow: clip;
	}

	.container {
		width: min(var(--container), calc(100% - (var(--gutter) * 2)));
		margin-inline: auto;
	}

	.narrow {
		width: min(var(--narrow), 100%);
		margin-inline: auto;
	}

	.section {
		padding-block: clamp(5rem, 10vw, 8.75rem);
	}

	.section--hero {
		padding-top: clamp(7rem, 12vw, 10rem);
		padding-bottom: clamp(4.5rem, 7vw, 6.5rem);
		min-height: 100dvh;
		display: flex;
		align-items: center;
	}

	.section--hero > .container,
	.section--venue > .container,
	.section--registry > .container {
		width: min(1480px, calc(100% - (var(--gutter) * 2)));
	}

	.eyebrow {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.45rem 0.85rem;
		border-radius: var(--radius-pill);
		background: rgba(255, 253, 252, 0.7);
		border: 1px solid rgba(183, 110, 121, 0.12);
		color: var(--color-secondary);
		font-size: 0.66rem;
		font-weight: 600;
		letter-spacing: 0.22em;
		text-transform: uppercase;
	}

	.eyebrow--centered {
		margin-inline: auto;
	}

	.display-title,
	.section-title,
	.registry-card h3,
	.hero-portrait__copy h2 {
		font-family: var(--font-serif);
		font-weight: 600;
		letter-spacing: -0.03em;
		line-height: 0.92;
		margin: 0;
	}

	.display-title {
		font-size: clamp(3.2rem, 8vw, 5.5rem);
	}

	.section-title {
		font-size: clamp(2.2rem, 5vw, 3.25rem);
		line-height: 0.98;
	}

	.body-lg,
	.body,
	.muted,
	.nav-brand__text,
	.nav-links__item,
	.detail-chip,
	.footer__meta,
	.footer__thanks {
		font-family: var(--font-sans);
	}

	.body-lg {
		font-size: clamp(1.125rem, 2.2vw, 1.35rem);
		line-height: 1.7;
		margin: 0;
	}

	.body {
		font-size: 1rem;
		margin: 0;
	}

	.muted {
		color: var(--color-text-soft);
	}

	.bezel {
		padding: 0.375rem;
		border-radius: var(--radius-xl);
		background: rgba(255, 253, 252, 0.5);
		border: 1px solid rgba(191, 165, 144, 0.22);
		box-shadow: var(--shadow-card);
	}

	.bezel--glass {
		background: rgba(255, 253, 252, 0.82);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
	}

	.bezel__inner {
		background: linear-gradient(180deg, rgba(255, 253, 252, 0.98), rgba(243, 238, 231, 0.86));
		border-radius: calc(var(--radius-xl) - 0.375rem);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.8);
	}

	.button {
		display: inline-flex;
		align-items: center;
		gap: 0.8rem;
		justify-content: center;
		padding: 0.45rem 0.45rem 0.45rem 1.2rem;
		min-height: 3.5rem;
		border-radius: var(--radius-pill);
		background: linear-gradient(180deg, var(--color-primary), var(--color-primary-strong));
		color: #fff8f2;
		border: 1px solid rgba(158, 89, 101, 0.18);
		box-shadow: 0 14px 30px rgba(183, 110, 121, 0.16);
		transition:
			transform 520ms var(--ease-fluid),
			box-shadow 520ms var(--ease-fluid),
			background-color 520ms var(--ease-fluid);
	}

	.button:hover {
		transform: translate3d(0, -2px, 0);
		box-shadow: 0 20px 34px rgba(183, 110, 121, 0.2);
	}

	.button:active {
		transform: translate3d(0, 1px, 0) scale(0.985);
	}

	.button--secondary {
		background: rgba(255, 253, 252, 0.8);
		color: var(--color-text);
		border: 1px solid rgba(191, 165, 144, 0.3);
		box-shadow: none;
	}

	.button__icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.55rem;
		height: 2.55rem;
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.18);
		border: 1px solid rgba(255, 255, 255, 0.15);
		transition: transform 520ms var(--ease-fluid), background-color 520ms var(--ease-fluid);
		will-change: transform;
	}

	.button--secondary .button__icon {
		background: rgba(183, 110, 121, 0.08);
		border-color: rgba(183, 110, 121, 0.12);
	}

	.button:hover .button__icon {
		transform: translate3d(5px, -2px, 0) scale(1.05);
	}

	.detail-chip {
		display: inline-flex;
		align-items: center;
		padding: 0.55rem 0.9rem;
		border-radius: var(--radius-pill);
		background: rgba(243, 238, 231, 0.9);
		border: 1px solid rgba(191, 165, 144, 0.2);
		font-size: 0.82rem;
		color: var(--color-text-soft);
	}

	.detail-chip--accent {
		background: rgba(255, 247, 245, 0.82);
		color: var(--color-primary-strong);
		border-color: rgba(183, 110, 121, 0.14);
	}

	[data-reveal] {
		opacity: 0;
		transform: translate3d(0, 2.4rem, 0);
		transition:
			opacity 900ms var(--ease-soft),
			transform 900ms var(--ease-soft);
	}

	[data-reveal].is-visible {
		opacity: 1;
		transform: translate3d(0, 0, 0);
	}

	.floating-nav-shell {
		position: fixed;
		inset: 0 0 auto 0;
		z-index: 3;
		pointer-events: none;
	}

	.floating-nav-wrap {
		padding-top: 1.5rem;
		display: flex;
		justify-content: center;
	}

	.floating-nav {
		width: min(100%, 860px);
		pointer-events: auto;
	}

	.floating-nav__inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.7rem 0.85rem 0.7rem 1rem;
	}

	.nav-brand,
	.menu-overlay__brand {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		font-size: 0.95rem;
		font-weight: 600;
	}

	.nav-brand__mark,
	.footer__monogram {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.5rem;
		height: 2.5rem;
		border-radius: 50%;
		border: 1px solid rgba(183, 110, 121, 0.2);
		background: rgba(255, 247, 245, 0.84);
		font-family: var(--font-serif);
		font-size: 1.05rem;
		letter-spacing: 0.06em;
	}

	.nav-links {
		display: inline-flex;
		align-items: center;
		gap: 0.25rem;
	}

	.nav-links__item {
		padding: 0.8rem 0.95rem;
		border-radius: var(--radius-pill);
		font-size: 0.92rem;
		color: var(--color-text-soft);
		transition: background-color 420ms var(--ease-fluid), color 420ms var(--ease-fluid), transform 420ms var(--ease-fluid);
	}

	.nav-links__item:hover {
		background: rgba(243, 238, 231, 0.9);
		color: var(--color-text);
		transform: translate3d(0, -1px, 0);
	}

	.nav-cta {
		white-space: nowrap;
	}

	.menu-toggle {
		display: none;
		position: relative;
		width: 3rem;
		height: 3rem;
		border-radius: 50%;
		border: 1px solid rgba(191, 165, 144, 0.24);
		background: rgba(255, 253, 252, 0.84);
	}

	.menu-toggle__line,
	.menu-overlay__close span {
		position: absolute;
		top: 50%;
		width: 1.1rem;
		height: 1px;
		background: var(--color-text);
		border-radius: 999px;
		transition: transform 520ms var(--ease-fluid), opacity 520ms var(--ease-fluid);
		transform-origin: center;
	}

	.menu-toggle__line {
		left: calc(50% - 0.55rem);
	}

	.menu-overlay__close span {
		left: 50%;
	}

	.menu-overlay {
		position: fixed;
		inset: 0;
		opacity: 0;
		pointer-events: none;
		background: rgba(250, 247, 242, 0.92);
		backdrop-filter: blur(14px);
		-webkit-backdrop-filter: blur(14px);
		overflow: auto;
		padding-inline: 1rem;
	}

	[data-floating-nav][data-open='true'] .menu-overlay {
		opacity: 1;
		pointer-events: auto;
	}

	.menu-overlay__veil {
		position: fixed;
		inset: 0;
		pointer-events: none;
	}

	.menu-overlay__orb {
		position: absolute;
		border-radius: 50%;
		filter: blur(12px);
		opacity: 0.8;
	}

	.menu-overlay__orb--rose {
		width: min(26rem, 65vw);
		height: min(26rem, 65vw);
		top: 10%;
		left: -4%;
		background: radial-gradient(circle, rgba(183, 110, 121, 0.34) 0%, rgba(183, 110, 121, 0.14) 38%, rgba(183, 110, 121, 0) 72%);
	}

	.menu-overlay__orb--champagne {
		width: min(22rem, 56vw);
		height: min(22rem, 56vw);
		right: -2%;
		bottom: 12%;
		background: radial-gradient(circle, rgba(216, 185, 138, 0.32) 0%, rgba(216, 185, 138, 0.12) 40%, rgba(216, 185, 138, 0) 72%);
	}

	.menu-overlay__panel {
		width: min(100% - 2rem, 38rem);
		margin: 6.5rem auto 0;
		padding: 1.35rem;
		border-radius: 2.2rem;
		background: linear-gradient(180deg, rgba(255, 253, 252, 0.96), rgba(243, 238, 231, 0.9));
		border: 1px solid rgba(191, 165, 144, 0.22);
		box-shadow: var(--shadow-soft);
		position: relative;
		z-index: 1;
	}

	.menu-overlay__header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
	}

	.menu-overlay__close {
		position: relative;
		width: 3rem;
		height: 3rem;
		border-radius: 50%;
		background: rgba(243, 238, 231, 0.86);
	}

	.menu-overlay__close span:first-child {
		transform: translate3d(-50%, 0, 0) rotate(45deg);
	}

	.menu-overlay__close span:last-child {
		transform: translate3d(-50%, 0, 0) rotate(-45deg);
	}

	.menu-overlay__nav {
		display: grid;
		gap: 0.75rem;
		margin-top: 2rem;
	}

	.menu-overlay__intro {
		display: grid;
		gap: 0.8rem;
		margin-top: 1.6rem;
	}

	.menu-overlay__lede,
	.menu-overlay__footer {
		margin: 0;
		color: var(--color-text-soft);
	}

	.menu-overlay__link {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1.1rem 1.2rem;
		border-radius: 1.4rem;
		background: rgba(255, 253, 252, 0.64);
		border: 1px solid rgba(191, 165, 144, 0.16);
		gap: 1rem;
	}

	.menu-overlay__link-index {
		font-size: 0.72rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--color-text-soft);
	}

	.menu-overlay__link-label {
		flex: 1;
		font-family: var(--font-serif);
		font-size: clamp(1.8rem, 4vw, 2.4rem);
		line-height: 1;
	}

	.menu-overlay__link-arrow {
		font-size: 1.1rem;
		color: var(--color-primary-strong);
	}

	.menu-overlay__cta {
		margin-top: 1.5rem;
	}

	.menu-overlay__footer {
		padding: 1.4rem 0 0.25rem;
		font-size: 0.92rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.hero__grid,
	.venue,
	.registry__grid {
		display: grid;
		grid-template-columns: minmax(0, 1.04fr) minmax(0, 0.96fr);
		gap: clamp(2rem, 5vw, 4.5rem);
		align-items: center;
